<style>
  /* ── Parchment Studios Landing Page ── */
  :root {
    --ps-bg: #0d0a06;
    --ps-cream: #F4E8C1;
    --ps-muted: #8a7a5a;
    --ps-gold: #C8960C;
    --ps-gold-dark: #a07510;
    --ps-card-bg: rgba(244, 232, 193, 0.04);
    --ps-card-border: rgba(200, 150, 12, 0.25);
  }

  @keyframes ps-float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-12px); }
  }

  @keyframes ps-shimmer {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
  }

  @keyframes ps-fade-up {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes ps-glow-pulse {
    0%, 100% { box-shadow: 0 0 20px rgba(200, 150, 12, 0.3), 0 0 40px rgba(200, 150, 12, 0.1); }
    50% { box-shadow: 0 0 30px rgba(200, 150, 12, 0.5), 0 0 60px rgba(200, 150, 12, 0.2); }
  }

  @keyframes ps-grain {
    0%, 100% { transform: translate(0, 0); }
    10% { transform: translate(-2%, -2%); }
    30% { transform: translate(1%, -3%); }
    50% { transform: translate(-3%, 1%); }
    70% { transform: translate(3%, 2%); }
    90% { transform: translate(1%, -1%); }
  }

  .ps-page { background-color: var(--ps-bg); min-height: 100vh; overflow-x: hidden; }

  .ps-grain::before {
    content: '';
    position: fixed;
    inset: -50%;
    width: 200%;
    height: 200%;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    opacity: 0.03;
    pointer-events: none;
    z-index: 1;
    animation: ps-grain 8s steps(10) infinite;
  }

  .ps-hero-img {
    mask-image: linear-gradient(to bottom, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.3) 60%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0.3) 60%, transparent 100%);
    animation: ps-float 8s ease-in-out infinite;
  }

  .ps-shimmer-text {
    background: linear-gradient(
      90deg,
      var(--ps-gold) 0%,
      #e8c252 25%,
      var(--ps-gold) 50%,
      #e8c252 75%,
      var(--ps-gold) 100%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: ps-shimmer 6s linear infinite;
  }

  .ps-cta {
    background: linear-gradient(135deg, var(--ps-gold) 0%, var(--ps-gold-dark) 100%);
    transition: all 0.3s ease;
  }
  .ps-cta:hover {
    animation: ps-glow-pulse 2s ease-in-out infinite;
    transform: translateY(-2px);
    background: linear-gradient(135deg, #d9a41e 0%, var(--ps-gold) 100%);
  }

  .ps-card {
    background: var(--ps-card-bg);
    border: 1px solid var(--ps-card-border);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    transition: all 0.3s ease;
  }
  .ps-card:hover {
    background: rgba(244, 232, 193, 0.07);
    border-color: rgba(200, 150, 12, 0.45);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3), 0 0 30px rgba(200, 150, 12, 0.08);
  }

  .ps-fade-up { animation: ps-fade-up 0.8s ease-out both; }
  .ps-fade-up-2 { animation: ps-fade-up 0.8s ease-out 0.15s both; }
  .ps-fade-up-3 { animation: ps-fade-up 0.8s ease-out 0.3s both; }
  .ps-fade-up-4 { animation: ps-fade-up 0.8s ease-out 0.45s both; }

  .ps-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--ps-card-border), transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .ps-hero-img, .ps-shimmer-text, .ps-grain::before { animation: none !important; }
    .ps-cta:hover { animation: none !important; }
    .ps-fade-up, .ps-fade-up-2, .ps-fade-up-3, .ps-fade-up-4 { animation: none !important; opacity: 1; }
  }
</style>

<div class="ps-page ps-grain" data-theme="dark">
  <!-- ═══════════ NAVIGATION ═══════════ -->
  <nav
    class="fixed top-0 left-0 right-0 z-50"
    style="background: rgba(13, 10, 6, 0.8); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-bottom: 1px solid rgba(200, 150, 12, 0.1);"
  >
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="flex h-16 items-center justify-between">
        <a href="/" class="flex items-center gap-3 cursor-pointer group">
          <svg
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            class="transition-transform duration-300 group-hover:scale-110"
          >
            <path
              d="M3 7c0-1.1.9-2 2-2h14a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"
              stroke="#C8960C"
              stroke-width="1.5"
              fill="none"
            />
            <path
              d="M7 5v14M3 9h18M3 13h4M17 13h4"
              stroke="#C8960C"
              stroke-width="1.5"
              stroke-linecap="round"
            />
            <circle cx="12" cy="12" r="2" fill="#C8960C" opacity="0.6" />
          </svg>
          <span style="font-family: 'Cinzel', serif; color: var(--ps-gold); font-size: 1.15rem; font-weight: 600; letter-spacing: 0.01em;">
            Parchment Studios
          </span>
        </a>
        <div class="hidden sm:flex items-center gap-8">
          <a
            href="#features"
            class="text-sm cursor-pointer transition-colors duration-200"
            style="color: var(--ps-muted); font-family: 'Inter', sans-serif;"
            onmouseover="this.style.color='#F4E8C1'"
            onmouseout="this.style.color='#8a7a5a'"
          >
            Features
          </a>
          <a
            href="#testimonial"
            class="text-sm cursor-pointer transition-colors duration-200"
            style="color: var(--ps-muted); font-family: 'Inter', sans-serif;"
            onmouseover="this.style.color='#F4E8C1'"
            onmouseout="this.style.color='#8a7a5a'"
          >
            Testimonials
          </a>
          <a
            href="#"
            class="ps-cta cursor-pointer inline-flex items-center px-5 py-2 rounded-lg text-sm font-semibold"
            style="color: var(--ps-bg); font-family: 'Inter', sans-serif;"
          >
            Early Access
          </a>
        </div>
      </div>
    </div>
  </nav>
  
<!-- ═══════════ HERO SECTION ═══════════ -->
  <section class="relative min-h-screen flex items-center overflow-hidden pt-16">
    <!-- Hero background image -->
    <div class="absolute inset-0 z-0">
      <img
        src="/images/hero-world-map.png"
        alt="Hand-painted fantasy world map on aged parchment"
        class="w-full h-full object-cover ps-hero-img"
        style="object-position: center 30%;"
      />
      <!-- Gradient overlays for text readability -->
      <div
        class="absolute inset-0"
        style="background: linear-gradient(to right, rgba(13,10,6,0.95) 0%, rgba(13,10,6,0.8) 40%, rgba(13,10,6,0.4) 70%, rgba(13,10,6,0.3) 100%);"
      >
      </div>
      <div
        class="absolute inset-0"
        style="background: linear-gradient(to bottom, rgba(13,10,6,0.3) 0%, rgba(13,10,6,0.1) 50%, rgba(13,10,6,0.95) 100%);"
      >
      </div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8 w-full">
      <div class="max-w-2xl py-24 lg:py-32">
        <h1
          class="ps-fade-up"
          style="font-family: 'Cinzel', serif; font-weight: 700; line-height: 1.1; margin: 0;"
        >
          <span
            class="block"
            style="font-size: clamp(2.8rem, 6vw, 4.5rem); color: var(--ps-cream);"
          >
            Build Fantasy Worlds.
          </span>
          <span class="block ps-shimmer-text mt-2" style="font-size: clamp(2.8rem, 6vw, 4.5rem);">
            Where Great Worlds Are Built.
          </span>
        </h1>

        <p
          class="ps-fade-up-2 mt-8 text-lg leading-relaxed max-w-xl"
          style="color: var(--ps-muted); font-family: 'Inter', sans-serif; font-weight: 300;"
        >
          The AI-powered worldbuilding studio for authors, dungeon masters, and game designers.
        </p>

        <div class="ps-fade-up-3 mt-10 flex flex-wrap items-center gap-4">
          <a
            href="#"
            class="ps-cta cursor-pointer inline-flex items-center gap-2 px-8 py-3.5 rounded-lg text-base font-semibold tracking-wide"
            style="color: var(--ps-bg); font-family: 'Inter', sans-serif;"
          >
            Request Early Access
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
            </svg>
          </a>
          <a
            href="#features"
            class="cursor-pointer inline-flex items-center gap-2 px-6 py-3.5 rounded-lg text-sm font-medium transition-colors duration-200"
            style="color: var(--ps-cream); font-family: 'Inter', sans-serif; border: 1px solid var(--ps-card-border);"
            onmouseover="this.style.borderColor='rgba(200,150,12,0.5)'; this.style.background='rgba(244,232,193,0.04)'"
            onmouseout="this.style.borderColor='rgba(200,150,12,0.25)'; this.style.background='transparent'"
          >
            Learn More
          </a>
        </div>
      </div>
    </div>
  </section>
  
<!-- ═══════════ FEATURES SECTION ═══════════ -->
  <section id="features" class="relative z-10 py-28 lg:py-36" style="background: var(--ps-bg);">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <!-- Section header -->
      <div class="text-center max-w-2xl mx-auto mb-20">
        <p
          class="text-xs font-semibold tracking-[0.25em] uppercase mb-4"
          style="color: var(--ps-gold); font-family: 'Inter', sans-serif;"
        >
          Everything you need
        </p>
        <h2 style="font-family: 'Cinzel', serif; font-size: clamp(1.8rem, 3.5vw, 2.8rem); font-weight: 600; color: var(--ps-cream); line-height: 1.2;">
          Craft worlds that feel alive
        </h2>
      </div>
      
<!-- Feature cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        <!-- Card 1: Living Maps -->
        <div class="ps-card rounded-xl p-8 lg:p-10 cursor-pointer">
          <div
            class="mb-6 w-12 h-12 rounded-lg flex items-center justify-center"
            style="background: rgba(200, 150, 12, 0.1); border: 1px solid rgba(200, 150, 12, 0.2);"
          >
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#C8960C"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M3 7l6-3 6 3 6-3v13l-6 3-6-3-6 3V7z" />
              <path d="M9 4v13" />
              <path d="M15 7v13" />
            </svg>
          </div>
          <h3
            class="text-xl font-semibold mb-3"
            style="font-family: 'Cinzel', serif; color: var(--ps-cream);"
          >
            Living Maps
          </h3>
          <p
            class="text-sm leading-relaxed"
            style="color: var(--ps-muted); font-family: 'Inter', sans-serif; font-weight: 300;"
          >
            Draw on layered parchment canvases. Place terrain, cities, and features with a full stamp system. Every layer compositable.
          </p>
        </div>
        
<!-- Card 2: AI Lore Generation -->
        <div class="ps-card rounded-xl p-8 lg:p-10 cursor-pointer">
          <div
            class="mb-6 w-12 h-12 rounded-lg flex items-center justify-center"
            style="background: rgba(200, 150, 12, 0.1); border: 1px solid rgba(200, 150, 12, 0.2);"
          >
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#C8960C"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M4 19.5v-15A2.5 2.5 0 016.5 2H20v20H6.5a2.5 2.5 0 010-5H20" />
              <path d="M8 7h6" />
              <path d="M8 11h8" />
            </svg>
          </div>
          <h3
            class="text-xl font-semibold mb-3"
            style="font-family: 'Cinzel', serif; color: var(--ps-cream);"
          >
            AI Lore Generation
          </h3>
          <p
            class="text-sm leading-relaxed"
            style="color: var(--ps-muted); font-family: 'Inter', sans-serif; font-weight: 300;"
          >
            Place a city and watch its name, history, factions, and story hooks appear — all linked to your map. The world writes itself.
          </p>
        </div>
        
<!-- Card 3: The Companion Book -->
        <div class="ps-card rounded-xl p-8 lg:p-10 cursor-pointer">
          <div
            class="mb-6 w-12 h-12 rounded-lg flex items-center justify-center"
            style="background: rgba(200, 150, 12, 0.1); border: 1px solid rgba(200, 150, 12, 0.2);"
          >
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#C8960C"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M14.5 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V7.5L14.5 2z" />
              <polyline points="14,2 14,8 20,8" />
              <path d="M8 13h8" />
              <path d="M8 17h8" />
              <path d="M8 9h2" />
            </svg>
          </div>
          <h3
            class="text-xl font-semibold mb-3"
            style="font-family: 'Cinzel', serif; color: var(--ps-cream);"
          >
            The Companion Book
          </h3>
          <p
            class="text-sm leading-relaxed"
            style="color: var(--ps-muted); font-family: 'Inter', sans-serif; font-weight: 300;"
          >
            Characters, creatures, factions, events — your world's lore as a living book, linked to every location on the map.
          </p>
        </div>
      </div>
    </div>
  </section>
  
<!-- ═══════════ TESTIMONIAL SECTION ═══════════ -->
  <section id="testimonial" class="relative z-10 py-24 lg:py-32" style="background: var(--ps-bg);">
    <div class="ps-divider mx-auto max-w-4xl mb-24"></div>
    <div class="mx-auto max-w-3xl px-6 lg:px-8 text-center">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" class="mx-auto mb-8 opacity-30">
        <path
          d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"
          fill="#C8960C"
        />
        <path
          d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"
          fill="#C8960C"
        />
      </svg>
      <blockquote>
        <p
          class="text-2xl lg:text-3xl leading-relaxed"
          style="font-family: 'Cinzel', serif; color: var(--ps-cream); font-weight: 400; font-style: italic;"
        >
          Finally, the worldbuilding tool I've been waiting for.
        </p>
      </blockquote>
      <div class="mt-8">
        <div class="w-10 h-px mx-auto mb-4" style="background: var(--ps-gold);"></div>
        <p
          class="text-sm tracking-wide"
          style="color: var(--ps-muted); font-family: 'Inter', sans-serif;"
        >
          Early Access User
        </p>
      </div>
    </div>
  </section>
  
<!-- ═══════════ FINAL CTA SECTION ═══════════ -->
  <section class="relative z-10 py-28 lg:py-36" style="background: var(--ps-bg);">
    <div class="ps-divider mx-auto max-w-4xl mb-24"></div>
    <div class="mx-auto max-w-3xl px-6 lg:px-8 text-center">
      <h2
        class="mb-6"
        style="font-family: 'Cinzel', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 600; color: var(--ps-cream); line-height: 1.2;"
      >
        Your world awaits
      </h2>
      <p
        class="text-lg mb-10 max-w-lg mx-auto"
        style="color: var(--ps-muted); font-family: 'Inter', sans-serif; font-weight: 300;"
      >
        Join creators building the next generation of fantasy worlds.
      </p>
      <a
        href="#"
        class="ps-cta cursor-pointer inline-flex items-center gap-2 px-10 py-4 rounded-lg text-base font-semibold tracking-wide"
        style="color: var(--ps-bg); font-family: 'Inter', sans-serif;"
      >
        Get Started
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
        </svg>
      </a>
    </div>
  </section>
  
<!-- ═══════════ FOOTER ═══════════ -->
  <footer class="relative z-10 py-12" style="background: var(--ps-bg);">
    <div class="ps-divider mx-auto max-w-7xl mb-12"></div>
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-3">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
            <path
              d="M3 7c0-1.1.9-2 2-2h14a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"
              stroke="#C8960C"
              stroke-width="1.5"
              fill="none"
            />
            <path d="M7 5v14M3 9h18" stroke="#C8960C" stroke-width="1.5" stroke-linecap="round" />
          </svg>
          <span class="text-sm" style="color: var(--ps-muted); font-family: 'Inter', sans-serif;">
            &copy; 2026 Parchment Studios. All rights reserved.
          </span>
        </div>
        <div class="flex items-center gap-6">
          <a
            href="#"
            class="text-xs cursor-pointer transition-colors duration-200"
            style="color: var(--ps-muted); font-family: 'Inter', sans-serif;"
            onmouseover="this.style.color='#F4E8C1'"
            onmouseout="this.style.color='#8a7a5a'"
          >
            Privacy
          </a>
          <a
            href="#"
            class="text-xs cursor-pointer transition-colors duration-200"
            style="color: var(--ps-muted); font-family: 'Inter', sans-serif;"
            onmouseover="this.style.color='#F4E8C1'"
            onmouseout="this.style.color='#8a7a5a'"
          >
            Terms
          </a>
          <a
            href="#"
            class="text-xs cursor-pointer transition-colors duration-200"
            style="color: var(--ps-muted); font-family: 'Inter', sans-serif;"
            onmouseover="this.style.color='#F4E8C1'"
            onmouseout="this.style.color='#8a7a5a'"
          >
            Contact
          </a>
        </div>
      </div>
    </div>
  </footer>
</div>
